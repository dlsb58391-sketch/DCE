{
  "name": "dental-site",
  "version": "0.1.0",
  "private": true,
  "description": "Clinva — modern, Arabic-first dental clinic management desktop app.",
  "author": "Clinva",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "db:backup": "node scripts/backup.mjs",
    "db:pg-backup": "node scripts/pg-backup.mjs",
    "db:restore": "node scripts/restore.mjs",
    "staging:sync": "node scripts/staging-sync.mjs",
    "health": "node scripts/healthcheck.mjs",
    "whatsapp:check": "node scripts/whatsapp-check.mjs",
    "whatsapp:worker": "node worker/whatsapp-web.mjs",
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "postinstall": "prisma generate",
    "desktop:setup": "npm i --no-save electron@33.4.11 electron-builder@25.1.8 sharp png-to-ico wait-on concurrently",
    "desktop:icon": "node scripts/make-icon.mjs",
    "desktop:dev": "concurrently -k -n next,electron \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "desktop:build": "node scripts/build-desktop.mjs"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "build": {
    "appId": "app.clinva.desktop",
    "productName": "Clinva",
    "copyright": "Copyright © 2026 Clinva",
    "asar": false,
    "directories": {
      "output": "dist-desktop",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app"
      },
      {
        "from": "prisma/clinva-seed.db",
        "to": "clinva-seed.db"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "artifactName": "Clinva-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Clinva"
    }
  },
  "engines": {
    "node": ">=20 <=22"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "optionalDependencies": {
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.26.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "node-cron": "^4.4.1",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
