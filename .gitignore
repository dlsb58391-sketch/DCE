# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# runtime logs & local server scaffolding
*.log
bdic-run.log
dev.log

# scratch / temp scripts (recorders, one-off probes)
_*.mjs
_*.py

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/prisma/dev.db
/prisma/dev.db-journal
# per-clinic databases (each clinic keeps its own private data)
/prisma/*.db
/prisma/*.db-journal

# standalone per-clinic export builds (regenerable via scripts/export-clinic.mjs)
/deploy
# per-clinic scaffold env + assets contain secrets / private files
/clinics/*/.env

# keep example env
!.env.example
!.env.railway.example

# patient file uploads (private)
/private-uploads

# backups (local DB + uploads snapshots)
/backups
# exported spreadsheets (contain patient data)
/exports
# staging working copy
/prisma/staging.db*

# playwright test artefacts
/test-results
/playwright-report

# whatsapp-web.js session (contains your WhatsApp login � NEVER commit)
/.wwebjs_auth
/.wwebjs_cache
wa-worker.log

# throwaway preview build dirs for non-default clinics
.next-*

# desktop (electron) build output + temp schema
/dist-desktop
/prisma/schema.desktop.prisma

# local clinic preview helper + logs
/run-ibrahim.cmd
ibrahim-dev*.log
