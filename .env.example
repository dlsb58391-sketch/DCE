# Copy to .env and fill in. Never commit the real .env.

# --- Database ---
# Dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Postgres on the VPS), example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bdic?schema=public"

# --- Auth ---
# REQUIRED. Must be >= 32 chars and NOT a placeholder. The app refuses to sign
# tokens with a weak/known value (e.g. "change-me") and logs a CRITICAL warning
# at boot. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me"

# --- App ---
APP_URL="https://your-domain.com"
# Optional: prefill the login form username (convenience for single-clinic installs).
NEXT_PUBLIC_LOGIN_USERNAME=""

# --- Timezone ---
# The clinic's timezone. Appointment slot/day computation reads the process
# timezone (via Date.setHours/getHours), so on a UTC host it would drift from
# the Cairo-formatted times patients see. Node reads TZ at process start.
# instrumentation.ts also defaults this to Africa/Cairo at boot if unset.
TZ="Africa/Cairo"

# --- WhatsApp automation ---
WHATSAPP_PROVIDER="mock"     # mock | metaCloud | wa
WHATSAPP_TOKEN=""            # Meta Cloud API permanent token
WHATSAPP_PHONE_ID=""         # Meta Cloud API phone number ID
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_DEFAULT_CC="20"

# Meta requires approved templates for proactive messages (see README -> WhatsApp setup)
WHATSAPP_USE_TEMPLATES="1"
WHATSAPP_TPL_RESERVED="bdic_booking_confirmed"
WHATSAPP_TPL_REMINDER="bdic_appointment_reminder"
WHATSAPP_TPL_QUEUE="bdic_queue_update"
WHATSAPP_TPL_TURN="bdic_your_turn"
WHATSAPP_LANG_EN="en"
WHATSAPP_LANG_AR="ar"

# --- Scheduler ---
REMINDER_LEAD_MIN="120"
QUEUE_LEAD_MIN="60"
SCHEDULER_ENABLED="1"
# Shared secret that authorizes the external cron trigger POST /api/admin/tick
# (sent as the `x-cron-secret` header). Lets a system crontab or uptime pinger
# drive reminders when the in-process scheduler is disabled. ALWAYS set a strong
# value in production.
CRON_SECRET=""

# --- Patient file uploads ---
UPLOADS_DIR="./private-uploads"

# --- SEO / Analytics (Phase 2) ---
# Public site URL (used for canonical, sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
# Google Analytics 4 (leave empty to disable)
NEXT_PUBLIC_GA_ID=""
# Meta (Facebook) Pixel (leave empty to disable)
NEXT_PUBLIC_FB_PIXEL_ID=""

# --- WhatsApp booking agent (inbound) ---
# Token YOU choose; enter the same value in the Meta webhook setup
WHATSAPP_VERIFY_TOKEN=""
# Meta App Secret � enables webhook signature verification (recommended)
WHATSAPP_APP_SECRET=""

# Dedicated clinic WhatsApp bot number (digits only, no +) � shown on the site's Confirm-on-WhatsApp button
NEXT_PUBLIC_CLINIC_WHATSAPP=""
# Sales/marketing WhatsApp number shown on the public product page (digits only, no +).
NEXT_PUBLIC_SALES_WHATSAPP=""

# --- WhatsApp Web worker (whatsapp-web.js, no Meta/card) ---
# Shared secret between the site and worker/whatsapp-web.mjs (set the SAME value in both).
WA_AGENT_SECRET=""
# Where the worker reaches the site (worker only):
APP_BASE_URL="http://localhost:3000"
# Where the worker persists its WhatsApp Web login session (worker only).
WA_SESSION_DIR="./.wwebjs_auth"
# Optional explicit Chrome/Chromium executable for the worker's headless browser.
# Leave empty to auto-detect the system Chrome install.
CHROME_PATH=""

# --- WhatsApp simulate endpoint ---
# Dev/testing only. With a non-"mock" provider the /api/whatsapp/simulate route is
# 404 unless this is set to 1 (and then it requires an authenticated session).
# NEVER set this to 1 in production. See docs/SECURITY.md.
WA_SIMULATE_ENABLED=""

# --- Database seeding (prisma/seed.mjs) ---
# The seed creates the initial doctor/admin login and never uses a hardcoded
# default password. In production SEED_DOCTOR_PASSWORD is MANDATORY (the seed
# refuses to create a login without it); in dev a random password is generated
# and printed once. EMAIL/USERNAME/NAME override the built-in clinic defaults.
SEED_DOCTOR_EMAIL=""
SEED_DOCTOR_USERNAME=""
SEED_DOCTOR_NAME=""
SEED_DOCTOR_PASSWORD=""

# --- Clinic selection (multi-clinic) ---
# Which clinic profile (slug) to load. Defaults to the built-in default clinic.
# NEXT_PUBLIC_CLINIC is read in the browser; CLINIC is the server-side fallback.
NEXT_PUBLIC_CLINIC=""
CLINIC=""

# --- Database backups (scripts/pg-backup.mjs, PostgreSQL only) ---
# Optional. `npm run db:pg-backup` dumps BACKUP_DATABASE_URL if set, else
# DATABASE_URL — point it at a read replica to keep backup load off the primary.
# BACKUP_DIR overrides the output directory (default ./backups/postgres).
# See docs/RUNBOOK.md section 5 for scheduling, retention and restore.
BACKUP_DATABASE_URL=""
BACKUP_DIR=""
